{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/upload", "dest": "/api/upload.py" },
    { "src": "/api/generate", "dest": "/api/generate.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
